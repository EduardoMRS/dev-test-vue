# Dependências (instaladas dentro da imagem)
node_modules/
vendor/

# Assets compilados (gerados no build da imagem)
public/build/
public/hot

# Git
.git/
.gitignore
.gitattributes

# Ambiente local — nunca deve entrar na imagem
.env
.env.*
!.env.example
!.env.docker-build

